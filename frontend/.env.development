# Development Environment - FieldVibe Frontend
# API Configuration (uses relative path for local dev server proxy)
VITE_API_BASE_URL=/api

# AI Features - Enable for local testing with Ollama
VITE_ENABLE_AI=true
VITE_AI_URL=http://localhost:11434/api

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_OFFLINE_MODE=true

# Performance Settings (shorter TTL for faster iteration)
VITE_CACHE_TTL_MS=30000
VITE_ENABLE_STALE_WHILE_REVALIDATE=true

# PWA Settings
VITE_PWA_ENABLED=true
VITE_APP_VERSION=1.0.0-dev
