# Production Environment - FieldVibe Frontend
# API Configuration
VITE_API_BASE_URL=https://fieldvibe-api.vantax.co.za/api

# AI Features - Disabled in production (requires local Ollama instance)
VITE_ENABLE_AI=false
VITE_AI_URL=http://localhost:11434/api

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_OFFLINE_MODE=true

# Performance Settings
VITE_CACHE_TTL_MS=120000
VITE_ENABLE_STALE_WHILE_REVALIDATE=true

# PWA Settings
VITE_PWA_ENABLED=true
VITE_APP_VERSION=1.0.0
