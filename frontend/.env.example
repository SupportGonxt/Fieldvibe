# FieldVibe Frontend Environment Variables

# API Configuration
VITE_API_BASE_URL=https://fieldvibe-api.vantax.co.za/api
# For local development, use: VITE_API_BASE_URL=/api

# AI Features Configuration (Optional - requires Ollama running locally)
VITE_ENABLE_AI=false
VITE_AI_URL=http://localhost:11434/api

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_OFFLINE_MODE=true

# Performance Settings
VITE_CACHE_TTL_MS=120000
VITE_ENABLE_STALE_WHILE_REVALIDATE=true

# Analytics (Optional)
# VITE_GTAG_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# PWA Settings
VITE_PWA_ENABLED=true
VITE_APP_VERSION=1.0.0
